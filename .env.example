# AI Interview Assistant — Environment Variables
# Copy this file to .env and fill in your values.

OPENROUTER_API_KEY=sk-or-v1-........

# Model to use for answer generation (swap freely without touching code)
# Options:
#   anthropic/claude-sonnet-4-5   ← default, best quality
#   openai/gpt-4o-mini            ← faster, cheaper
#   google/gemini-flash-3.1       ← very fast, low latency
#   meta-llama/llama-3.1-70b-instruct ← free tier on OpenRouter
OPENROUTER_MODEL=google/gemini-3.1-flash-lite:nitro

# Whisper model size (base = fast, small = more accurate, medium = best)
WHISPER_MODEL=small
